{
    "name": "tina4stack/tina4php-queue",
    "description": "Queueing for Tina4Php",
    "license": "MIT",
    "autoload": {
        "files": [
            "Tina4/Initialize.php"
        ],
        "psr-4": {
            "Tina4\\": [
                "Tina4/"
            ]
        }
    },
    "authors": [
        {
            "name": "Andre van Zuydam",
            "email": "andrevanzuydam@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-sqlite3": "*",
        "ext-bcmath": "*",
        "tina4stack/tina4php-debug": "^2.0"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "phpunit/phpunit": "^9",
        "overtrue/phplint": "^2.0"
    },
    "suggest": {
        "php-amqplib/php-amqplib": "Required for RabbitMQ backend (^3.7)",
        "mongodb/mongodb": "Required for MongoDB backend (^1.21)",
        "ext-rdkafka": "Required for Kafka backend"
    },
    "scripts": {
        "test": "./vendor/bin/phpunit tests --color --log-junit=tests/junit.xml",
        "phpmetrics": "phpmetrics --report-html=phpmetrics --junit=tests/junit.xml ./Tina4"
    }
}
